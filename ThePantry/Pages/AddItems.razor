@page "/add-items"
@using MediatR
@using ThePantry.Application.Commands
@using ThePantry.Application.Queries
@inject IMediator Mediator
@inject ILogger<AddItems> Logger

<PageTitle>Add Items - ThePantry</PageTitle>

<h1>Add Items</h1>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "manual" ? "active" : "")" @onclick="() => SetTab("manual")">
            Manual Entry
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "csv" ? "active" : "")" @onclick="() => SetTab("csv")">
            CSV Upload
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "scan" ? "active" : "")" @onclick="() => SetTab("scan")">
            Scan UPC
        </button>
    </li>
</ul>

<div class="tab-content">
    @* Manual Entry Tab *@
    @if (activeTab == "manual")
    {
        <div class="card">
            <div class="card-body">
                <EditForm Model="@manualModel" OnValidSubmit="HandleManualSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name *</label>
                            <InputText class="form-control" @bind-Value="manualModel.Name" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Category</label>
                            <InputSelect class="form-select" @bind-Value="manualModel.Category">
                                <option value="Pantry">Pantry</option>
                                <option value="Refrigerator">Refrigerator</option>
                                <option value="Freezer">Freezer</option>
                                <option value="Spices">Spices</option>
                                <option value="Other">Other</option>
                            </InputSelect>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <InputText class="form-control" @bind-Value="manualModel.Description" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">On Hand Count</label>
                            <InputNumber class="form-control" @bind-Value="manualModel.OnHandCount" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Minimum Threshold</label>
                            <InputNumber class="form-control" @bind-Value="manualModel.MinimumThreshold" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">UPC (optional)</label>
                            <InputText class="form-control" @bind-Value="manualModel.UPC" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">Add Item</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* CSV Upload Tab *@
    @if (activeTab == "csv")
    {
        <div class="card">
            <div class="card-body">
                <p class="text-muted">
                    Upload a CSV file with columns: Name, Description, Category, OnHandCount, MinimumThreshold, UPC
                </p>
                <InputFile OnChange="HandleCsvUpload" accept=".csv" />
                
                @if (csvProcessing)
                {
                    <p class="mt-3"><em>Processing CSV...</em></p>
                }
                
                @if (csvResults.Count > 0)
                {
                    <div class="mt-3">
                        <h5>Results:</h5>
                        <p class="text-success">Successfully imported @csvResults.Count items.</p>
                    </div>
                }
            </div>
        </div>
    }

    @* Scan UPC Tab *@
    @if (activeTab == "scan")
    {
        <div class="card">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Enter UPC Code</label>
                    <div class="input-group">
                        <input type="text" class="form-control" @bind="scanUPC" @onkeydown="HandleScanKeyDown" 
                               placeholder="Scan or type UPC..." autofocus />
                        <button class="btn btn-primary" @onclick="HandleScanSubmit" disabled="@string.IsNullOrWhiteSpace(scanUPC)">
                            Scan
                        </button>
                    </div>
                    <small class="text-muted">Press Enter to submit</small>
                </div>
                
                @if (recentScans.Count > 0)
                {
                    <div class="mt-3">
                        <h5>Recent Scans:</h5>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>UPC</th>
                                    <th>Status</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var scan in recentScans)
                                {
                                    <tr>
                                        <td>@scan.UPC</td>
                                        <td>
                                            <span class="badge bg-@GetScanStatusBadge(scan.Status)">
                                                @scan.Status
                                            </span>
                                        </td>
                                        <td>@scan.Timestamp.ToString("HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string activeTab = "manual";
    private ManualEntryModel manualModel = new();
    private string scanUPC = "";
    private bool csvProcessing = false;
    private List<InventoryItem> csvResults = new();
    private List<ScanQueueItem> recentScans = new();
    private System.Timers.Timer? refreshTimer;

    private class ManualEntryModel
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string Category { get; set; } = "Pantry";
        public int OnHandCount { get; set; } = 1;
        public int MinimumThreshold { get; set; } = 1;
        public string? UPC { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRecentScans();
        // Start polling for scan updates
        refreshTimer = new System.Timers.Timer(3000);
        refreshTimer.Elapsed += async (s, e) =>
        {
            refreshTimer?.Stop();
            await InvokeAsync(async () => await LoadRecentScans());
        };
        refreshTimer.Start();
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private async Task HandleManualSubmit()
    {
        var item = await Mediator.Send(new AddInventoryItemCommand(
            manualModel.Name,
            manualModel.Description,
            manualModel.Category,
            manualModel.OnHandCount,
            manualModel.MinimumThreshold,
            manualModel.UPC
        ));
        
        // Reset form
        manualModel = new ManualEntryModel();
        
        Logger.LogInformation("Added inventory item: {Name}", item.Name);
    }

    private async Task HandleCsvUpload(InputFileChangeEventArgs e)
    {
        csvProcessing = true;
        csvResults.Clear();
        
        try
        {
            var file = e.File;
            using var reader = new StreamReader(file.OpenReadStream());
            var content = await reader.ReadToEndAsync();
            
            var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);
            var isFirstLine = true;
            
            foreach (var line in lines)
            {
                if (isFirstLine)
                {
                    isFirstLine = false;
                    continue; // Skip header
                }
                
                var parts = line.Split(',');
                if (parts.Length >= 2)
                {
                    try
                    {
                        var item = await Mediator.Send(new AddInventoryItemCommand(
                            Name: parts[0].Trim().Trim('"'),
                            Description: parts.Length > 1 ? parts[1].Trim().Trim('"') : null,
                            Category: parts.Length > 2 ? parts[2].Trim().Trim('"') : "Pantry",
                            OnHandCount: parts.Length > 3 && int.TryParse(parts[3].Trim(), out var qty) ? qty : 1,
                            MinimumThreshold: parts.Length > 4 && int.TryParse(parts[4].Trim(), out var min) ? min : 1,
                            UPC: parts.Length > 5 ? parts[5].Trim().Trim('"') : null
                        ));
                        csvResults.Add(item);
                    }
                    catch (Exception ex)
                    {
                        Logger.LogError(ex, "Error parsing CSV line: {Line}", line);
                    }
                }
            }
        }
        finally
        {
            csvProcessing = false;
        }
    }

    private async Task HandleScanKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleScanSubmit();
        }
    }

    private async Task HandleScanSubmit()
    {
        if (string.IsNullOrWhiteSpace(scanUPC))
            return;
        
        var upc = scanUPC.Trim();
        await Mediator.Send(new QueueScanCommand(upc));
        
        Logger.LogInformation("Queued UPC for scanning: {UPC}", upc);
        
        scanUPC = "";
        await LoadRecentScans();
    }

    private async Task LoadRecentScans()
    {
        var scans = await Mediator.Send(new GetScanQueueQuery());
        recentScans = scans.Take(10).ToList();
    }

    private string GetScanStatusBadge(ScanStatus status)
    {
        return status switch
        {
            ScanStatus.Pending => "secondary",
            ScanStatus.Processing => "info",
            ScanStatus.Complete => "success",
            ScanStatus.Failed => "danger",
            ScanStatus.Resolved => "warning",
            _ => "secondary"
        };
    }
}