@page "/scan-monitor"
@using MediatR
@using ThePantry.Application.Commands
@using ThePantry.Application.Queries
@using ThePantry.Domain
@inject IMediator Mediator
@inject ILogger<ScanMonitor> Logger

<PageTitle>Scan Monitor - ThePantry</PageTitle>

<h1>Scan Monitor</h1>

<div class="row mb-3">
    <div class="col">
        <div class="btn-group" role="group">
            <button class="btn @(statusFilter == null ? "btn-primary" : "btn-outline-primary")" 
                    @onclick="() => ApplyFilter(null)">
                All
            </button>
            <button class="btn @(statusFilter == ScanStatus.Pending ? "btn-primary" : "btn-outline-primary")" 
                    @onclick="() => ApplyFilter(ScanStatus.Pending)">
                Pending
            </button>
            <button class="btn @(statusFilter == ScanStatus.Processing ? "btn-primary" : "btn-outline-primary")" 
                    @onclick="() => ApplyFilter(ScanStatus.Processing)">
                Processing
            </button>
            <button class="btn @(statusFilter == ScanStatus.Failed ? "btn-primary" : "btn-outline-primary")" 
                    @onclick="() => ApplyFilter(ScanStatus.Failed)">
                Failed
            </button>
            <button class="btn @(statusFilter == ScanStatus.Complete ? "btn-primary" : "btn-outline-primary")" 
                    @onclick="() => ApplyFilter(ScanStatus.Complete)">
                Complete
            </button>
        </div>
    </div>
    <div class="col-auto">
        <button class="btn btn-secondary" @onclick="RefreshQueue">
            <span class="oi oi-reload"></span> Refresh
        </button>
    </div>
</div>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (scanItems.Count == 0)
{
    <div class="alert alert-info">
        No scan items found. Go to "Add Items" to scan some UPCs!
    </div>
}
else
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>UPC</th>
                <th>Product Name</th>
                <th>Status</th>
                <th>Timestamp</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in scanItems)
            {
                <tr class="@GetRowClass(item.Status)">
                    <td>
                        <code>@item.UPC</code>
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ProductName))
                        {
                            @item.ProductName
                        }
                        else if (item.Status == ScanStatus.Failed)
                        {
                            <em class="text-muted">Not found</em>
                        }
                        else
                        {
                            <em class="text-muted">Processing...</em>
                        }
                    </td>
                    <td>
                        <span class="badge bg-@GetStatusBadge(item.Status)">
                            @item.Status
                        </span>
                    </td>
                    <td>@item.Timestamp.ToString("g")</td>
                    <td>
                        @if (item.Status == ScanStatus.Failed)
                        {
                            <button class="btn btn-sm btn-warning" @onclick="() => ShowReviewModal(item)">
                                Review
                            </button>
                        }
                        else if (item.Status == ScanStatus.Complete && item.LinkedInventoryItemId.HasValue)
                        {
                            <span class="text-success">Added to inventory</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@* Review Modal *@
@if (showReviewModal && selectedItem != null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Review Failed Scan: @selectedItem.UPC</h5>
                    <button type="button" class="btn-close" @onclick="CloseReviewModal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">The product was not found in the database. Please enter details manually:</p>
                    
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input type="text" class="form-control" @bind="reviewModel.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input type="text" class="form-control" @bind="reviewModel.Description" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select class="form-select" @bind="reviewModel.Category">
                            <option value="Pantry">Pantry</option>
                            <option value="Refrigerator">Refrigerator</option>
                            <option value="Freezer">Freezer</option>
                            <option value="Spices">Spices</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col">
                            <label class="form-label">On Hand</label>
                            <input type="number" class="form-control" @bind="reviewModel.OnHandCount" />
                        </div>
                        <div class="col">
                            <label class="form-label">Minimum</label>
                            <input type="number" class="form-control" @bind="reviewModel.MinimumThreshold" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseReviewModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SubmitReview" disabled="@string.IsNullOrWhiteSpace(reviewModel.Name)">
                        Add to Inventory
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ScanQueueItem> scanItems = new();
    private ScanStatus? statusFilter = null;
    private bool isLoading = true;
    private System.Timers.Timer? refreshTimer;
    
    // Review modal
    private bool showReviewModal = false;
    private ScanQueueItem? selectedItem;
    private ReviewModel reviewModel = new();

    private class ReviewModel
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string Category { get; set; } = "Pantry";
        public int OnHandCount { get; set; } = 1;
        public int MinimumThreshold { get; set; } = 1;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadScanQueue();
        
        // Auto-refresh every 5 seconds
        refreshTimer = new System.Timers.Timer(5000);
        refreshTimer.Elapsed += async (s, e) =>
        {
            refreshTimer?.Stop();
            await InvokeAsync(async () => await LoadScanQueue());
        };
        refreshTimer.Start();
    }

    private async Task LoadScanQueue()
    {
        isLoading = true;
        try
        {
            scanItems = await Mediator.Send(new GetScanQueueQuery(statusFilter));
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilter(ScanStatus? status)
    {
        statusFilter = status;
        await LoadScanQueue();
    }

    private async Task RefreshQueue()
    {
        await LoadScanQueue();
    }

    private string GetStatusBadge(ScanStatus status)
    {
        return status switch
        {
            ScanStatus.Pending => "secondary",
            ScanStatus.Processing => "info",
            ScanStatus.Complete => "success",
            ScanStatus.Failed => "danger",
            ScanStatus.Resolved => "warning",
            _ => "secondary"
        };
    }

    private string GetRowClass(ScanStatus status)
    {
        return status switch
        {
            ScanStatus.Failed => "table-danger",
            ScanStatus.Complete => "table-success",
            _ => ""
        };
    }

    private void ShowReviewModal(ScanQueueItem item)
    {
        selectedItem = item;
        reviewModel = new ReviewModel
        {
            Name = item.ProductName ?? "",
            Description = item.ProductDescription,
            Category = "Pantry",
            OnHandCount = 1,
            MinimumThreshold = 1
        };
        showReviewModal = true;
    }

    private void CloseReviewModal()
    {
        showReviewModal = false;
        selectedItem = null;
    }

    private async Task SubmitReview()
    {
        if (selectedItem == null || string.IsNullOrWhiteSpace(reviewModel.Name))
            return;

        // Add to inventory
        var item = await Mediator.Send(new AddInventoryItemCommand(
            reviewModel.Name,
            reviewModel.Description,
            reviewModel.Category,
            reviewModel.OnHandCount,
            reviewModel.MinimumThreshold,
            selectedItem.UPC
        ));

        // Update scan item status
        await Mediator.Send(new UpdateScanQueueItemCommand(
            selectedItem.Id,
            ScanStatus.Resolved,
            item.Id
        ));
        
        Logger.LogInformation("Manually added item from failed scan: {Name}", item.Name);
        
        CloseReviewModal();
        await LoadScanQueue();
    }
}