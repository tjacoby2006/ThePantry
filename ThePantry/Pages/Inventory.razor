@page "/inventory"
@using ThePantry.Application.Queries
@using ThePantry.Application.Commands
@using ThePantry.Domain
@using ThePantry.Services
@using System.Text
@inject IMediator Mediator
@inject ToastService ToastService
@inject IJSRuntime JSRuntime

<PageTitle>Inventory - The Pantry</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Inventory</h1>
    @if (selectedItemIds.Any())
    {
        <button class="btn btn-warning" @onclick="CombineSelectedItems" disabled="@(selectedItemIds.Count < 2)">
            <span class="oi oi-layers"></span> Combine Selected (@selectedItemIds.Count)
        </button>
    }
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <span class="oi oi-magnifying-glass text-muted"></span>
                    </span>
                    <input type="text" class="form-control border-start-0" placeholder="Search items..." @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="selectedCategory">
                    <option value="">All Categories</option>
                    <option value="Pantry">Pantry</option>
                    <option value="Refrigerator">Refrigerator</option>
                    <option value="Freezer">Freezer</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="Search">Search</button>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" @onclick="ExportToCsv">
                    <span class="oi oi-share-boxed"></span> Export
                </button>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (inventoryItems == null || inventoryItems.Count == 0)
{
    <div class="card text-center py-5">
        <div class="card-body">
            <span class="oi oi-info display-4 text-muted mb-3"></span>
            <p class="text-muted">No inventory items found matching your criteria.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 40px;">
                            <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" checked="@IsAllSelected" />
                        </th>
                        <th style="width: 60px;"></th>
                        <th @onclick='() => Sort("name")' style="cursor:pointer">
                            Name @GetSortIcon("name")
                        </th>
                        <th @onclick='() => Sort("category")' style="cursor:pointer">
                            Category @GetSortIcon("category")
                        </th>
                        <th @onclick='() => Sort("onhand")' style="cursor:pointer" class="text-center">
                            On Hand @GetSortIcon("onhand")
                        </th>
                        <th @onclick='() => Sort("min")' style="cursor:pointer" class="text-center">
                            Min @GetSortIcon("min")
                        </th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in inventoryItems)
                    {
                        <tr>
                            <td class="text-center align-middle">
                                <input type="checkbox" class="form-check-input" 
                                       checked="@selectedItemIds.Contains(item.Id)" 
                                       @onchange="@(e => ToggleItemSelection(item.Id, e.Value))" />
                            </td>
                            <td class="text-center align-middle">
                                <ThePantry.Shared.Components.ProductImage ImageUrl="@item.ImageUrl" Size="ThePantry.Shared.Components.ProductImage.ImageSize.Thumb" Style="width: 40px; height: 40px; object-fit: contain; border-radius: 4px;" />
                            </td>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <div class="text-muted small">@item.Description</div>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark">@item.Category</span></td>
                            <td class="text-center fw-bold">@item.OnHandCount</td>
                            <td class="text-center text-muted">@item.MinimumThreshold</td>
                            <td class="text-center">
                                @if (item.IsBelowThreshold)
                                {
                                    <span class="badge bg-warning text-dark">Low Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">In Stock</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a href="inventory/details/@item.Id" class="btn btn-sm btn-outline-info" title="View Details">
                                    <span class="oi oi-eye"></span>
                                </a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DecrementItem(item.Id)" title="Use Item">
                                    <span class="oi oi-minus"></span>
                                </button>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => IncrementItem(item.Id)" title="Add Item">
                                    <span class="oi oi-plus"></span>
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditItem(item)" title="Edit Item">
                                    <span class="oi oi-pencil"></span>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(item)" title="Delete Item">
                                    <span class="oi oi-trash"></span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (showEditModal && editingItem != null)
    {
        <div class="modal fade show" style="display:block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Item</h5>
                        <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                    </div>
                    <div class="modal-body">
                        <EditForm Model="editingItem" OnValidSubmit="UpdateItem">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="editingItem.Name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Category</label>
                                <InputSelect class="form-select" @bind-Value="editingItem.Category">
                                    <option value="Pantry">Pantry</option>
                                    <option value="Refrigerator">Refrigerator</option>
                                    <option value="Freezer">Freezer</option>
                                </InputSelect>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <InputText class="form-control" @bind-Value="editingItem.Description" />
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">On Hand</label>
                                    <InputNumber class="form-control" @bind-Value="editingItem.OnHandCount" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Min Threshold</label>
                                    <InputNumber class="form-control" @bind-Value="editingItem.MinimumThreshold" />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">SKUs (comma separated)</label>
                                <input type="text" class="form-control" value="@string.Join(", ", editingItem.Skus)" 
                                       @onchange="@(e => editingItem.Skus = e.Value?.ToString()?.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList() ?? new List<string>())" />
                            </div>
                            <div class="modal-footer px-0 pb-0">
                                <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save Changes</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }

    @if (showDeleteModal && itemToDelete != null)
    {
        <div class="modal fade show" style="display:block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" @onclick="CloseDeleteModal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete <strong>@itemToDelete.Name</strong>?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                        <button type="button" class="btn btn-danger" @onclick="DeleteItem">Delete</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    }
    
    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">Previous</button>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    var pageNumber = i;
                    <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">Next</button>
                </li>
            </ul>
        </nav>
    }
</div>
}

@code {
    private List<InventoryItemDto>? inventoryItems;
    private string searchTerm = "";
    private string selectedCategory = "";
    private int currentPage = 1;
    private int totalPages = 1;
    private bool isLoading = true;

    private string sortBy = "name";
    private bool sortDescending = false;

    private bool showEditModal = false;
    private InventoryItemDto? editingItem;
    private bool showDeleteModal = false;
    private InventoryItemDto? itemToDelete;
    private List<int> selectedItemIds = new();

    private bool IsAllSelected => inventoryItems != null && inventoryItems.Any() && inventoryItems.All(i => selectedItemIds.Contains(i.Id));

    private void ToggleItemSelection(int itemId, object? checkedValue)
    {
        bool isChecked = checkedValue is bool b && b;
        if (isChecked)
        {
            if (!selectedItemIds.Contains(itemId))
            {
                selectedItemIds.Add(itemId);
            }
        }
        else
        {
            selectedItemIds.Remove(itemId);
        }
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool isChecked = e.Value is bool b && b;
        if (isChecked && inventoryItems != null)
        {
            foreach (var item in inventoryItems)
            {
                if (!selectedItemIds.Contains(item.Id))
                {
                    selectedItemIds.Add(item.Id);
                }
            }
        }
        else if (inventoryItems != null)
        {
            foreach (var item in inventoryItems)
            {
                selectedItemIds.Remove(item.Id);
            }
        }
    }

    private async Task CombineSelectedItems()
    {
        if (selectedItemIds.Count < 2) return;

        try
        {
            var result = await Mediator.Send(new CombineInventoryItemsCommand(selectedItemIds.ToList()));
            if (result)
            {
                await ToastService.ShowSuccess("Items combined successfully");
                selectedItemIds.Clear();
                await LoadInventory();
            }
            else
            {
                await ToastService.ShowError("Failed to combine items");
            }
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error combining items");
            Console.WriteLine($"Error combining items: {ex.Message}");
        }
    }
    
    protected override async Task OnInitializedAsync()
    {
        await LoadInventory();
    }
    
    private async Task LoadInventory()
    {
        isLoading = true;
        try
        {
            var result = await Mediator.Send(new GetInventoryListQuery(
                SearchTerm: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                Category: string.IsNullOrWhiteSpace(selectedCategory) ? null : selectedCategory,
                Page: currentPage,
                PageSize: 20,
                SortBy: sortBy,
                SortDescending: sortDescending
            ));
            
            inventoryItems = result.Items;
            totalPages = result.TotalPages;
        }
        catch (Exception ex)
        {
            // Log error
            Console.WriteLine($"Error loading inventory: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task Search()
    {
        currentPage = 1;
        await LoadInventory();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }
    
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        await LoadInventory();
    }
    
    private async Task DecrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new DecrementInventoryCommand(itemId));
            await ToastService.ShowInfo("Item count decreased");
            await LoadInventory();
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error updating item");
            Console.WriteLine($"Error decrementing item {itemId}: {ex.Message}");
        }
    }
    
    private async Task IncrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new IncrementInventoryCommand(itemId));
            await ToastService.ShowSuccess("Item count increased");
            await LoadInventory();
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error updating item");
            Console.WriteLine($"Error incrementing item {itemId}: {ex.Message}");
        }
    }

    private async Task ExportToCsv()
    {
        try
        {
            var result = await Mediator.Send(new GetInventoryListQuery(
                SearchTerm: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                Category: string.IsNullOrWhiteSpace(selectedCategory) ? null : selectedCategory,
                Page: 1,
                PageSize: 1000 // Export all matching items
            ));

            var csv = new StringBuilder();
            csv.AppendLine("Name,Description,Category,OnHandCount,MinimumThreshold,Skus");

            foreach (var item in result.Items)
            {
                var skus = string.Join(";", item.Skus);
                csv.AppendLine($"\"{item.Name}\",\"{item.Description}\",\"{item.Category}\",{item.OnHandCount},{item.MinimumThreshold},\"{skus}\"");
            }

            var fileName = $"Inventory_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, csv.ToString());
            await ToastService.ShowSuccess("Inventory exported successfully");
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error exporting inventory");
            Console.WriteLine($"Error exporting: {ex.Message}");
        }
    }

    private async Task Sort(string column)
    {
        if (sortBy == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortBy = column;
            sortDescending = false;
        }
        await LoadInventory();
    }

    private string GetSortIcon(string column)
    {
        if (sortBy != column) return "";
        return sortDescending ? "▼" : "▲";
    }

    private void EditItem(InventoryItemDto item)
    {
        editingItem = new InventoryItemDto
        {
            Id = item.Id,
            Name = item.Name,
            Description = item.Description,
            Category = item.Category,
            OnHandCount = item.OnHandCount,
            MinimumThreshold = item.MinimumThreshold,
            Skus = new List<string>(item.Skus)
        };
        showEditModal = true;
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        editingItem = null;
    }

    private async Task UpdateItem()
    {
        if (editingItem == null) return;

        try
        {
            await Mediator.Send(new UpdateInventoryItemCommand(
                editingItem.Id,
                editingItem.Name,
                editingItem.Description,
                editingItem.Category,
                editingItem.OnHandCount,
                editingItem.MinimumThreshold,
                editingItem.ImageUrl,
                editingItem.Skus
            ));
            await ToastService.ShowSuccess($"{editingItem.Name} updated successfully");
            CloseEditModal();
            await LoadInventory();
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error updating item");
            Console.WriteLine($"Error updating item: {ex.Message}");
        }
    }

    private void ConfirmDelete(InventoryItemDto item)
    {
        itemToDelete = item;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        itemToDelete = null;
    }

    private async Task DeleteItem()
    {
        if (itemToDelete == null) return;

        try
        {
            var name = itemToDelete.Name;
            await Mediator.Send(new DeleteInventoryItemCommand(itemToDelete.Id));
            await ToastService.ShowWarning($"{name} deleted");
            CloseDeleteModal();
            await LoadInventory();
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error deleting item");
            Console.WriteLine($"Error deleting item: {ex.Message}");
        }
    }
}