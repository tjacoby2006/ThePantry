@page "/"
@using MediatR
@using ThePantry.Application.Commands
@using ThePantry.Application.Queries
@using ThePantry.Services
@inject IMediator Mediator
@inject ILogger<Dashboard> Logger
@inject ToastService ToastService

<PageTitle>Dashboard - The Pantry</PageTitle>

<h1>Dashboard</h1>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5 class="card-title">Total Items</h5>
                <h2 class="card-text">@totalItemsCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h5 class="card-title">Low Stock</h5>
                <h2 class="card-text">@lowStockCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h5 class="card-title">Pending Scans</h5>
                <h2 class="card-text">@pendingScansCount</h2>
            </div>
        </div>
    </div>
</div>

@if (lowStockItems != null && lowStockItems.Any())
{
    <div class="card mb-4 border-warning">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Low Stock Alert</h5>
        </div>
        <div class="card-body p-0">
            <ul class="list-group list-group-flush">
                @foreach (var item in lowStockItems)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@item.Name</strong>
                            <span class="text-muted ms-2">(@item.Category)</span>
                        </div>
                        <div>
                            <span class="badge bg-danger rounded-pill me-2">@item.OnHandCount / @item.MinimumThreshold</span>
                            <button class="btn btn-sm btn-outline-success" @onclick="() => IncrementItem(item.Id)">
                                <span class="oi oi-plus"></span>
                            </button>
                        </div>
                    </li>
                }
            </ul>
        </div>
        <div class="card-footer text-end">
            <a href="shopping-list" class="btn btn-sm btn-primary">View Shopping List</a>
        </div>
    </div>
}

<h3>Quick Inventory Search</h3>

<div class="mb-3">
    <div class="row g-2">
        <div class="col-md-6">
            <input type="text" class="form-control" placeholder="Search items..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select" @bind="selectedCategory">
                <option value="">All Categories</option>
                <option value="Pantry">Pantry</option>
                <option value="Refrigerator">Refrigerator</option>
                <option value="Freezer">Freezer</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" @onclick="Search">Search</button>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (inventoryItems == null || inventoryItems.Count == 0)
{
    <div class="alert alert-info">
        No inventory items found. Go to "Add Items" to add your first item!
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th class="text-center">On Hand</th>
                    <th class="text-center">Min</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in inventoryItems)
                {
                    <tr class="@(item.IsBelowThreshold ? "table-warning" : "")">
                        <td>
                            <strong>@item.Name</strong>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <br /><small class="text-muted">@item.Description</small>
                            }
                        </td>
                        <td>@item.Category</td>
                        <td class="text-center">@item.OnHandCount</td>
                        <td class="text-center">@item.MinimumThreshold</td>
                        <td class="text-center">
                            @if (item.IsBelowThreshold)
                            {
                                <span class="badge bg-warning text-dark">Low Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">In Stock</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DecrementItem(item.Id)" title="Use Item">
                                    <span class="oi oi-minus"></span>
                                </button>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => IncrementItem(item.Id)" title="Add Item">
                                    <span class="oi oi-plus"></span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<InventoryItemDto>? inventoryItems;
    private List<InventoryItemDto>? lowStockItems;
    private int totalItemsCount;
    private int lowStockCount;
    private int pendingScansCount;
    
    private string searchTerm = "";
    private string selectedCategory = "";
    private bool isLoading = true;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }
    
    private async Task LoadDashboardData()
    {
        isLoading = true;
        try
        {
            // Load inventory for search
            var inventoryResult = await Mediator.Send(new GetInventoryListQuery(
                SearchTerm: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                Category: string.IsNullOrWhiteSpace(selectedCategory) ? null : selectedCategory,
                Page: 1,
                PageSize: 10
            ));
            inventoryItems = inventoryResult.Items;
            totalItemsCount = inventoryResult.TotalCount;

            // Load low stock items
            var shoppingList = await Mediator.Send(new GetShoppingListQuery());
            lowStockCount = shoppingList.Count;
            lowStockItems = shoppingList.Select(s => new InventoryItemDto 
            { 
                Id = s.Id, 
                Name = s.Name, 
                Category = s.Category, 
                OnHandCount = s.OnHandCount, 
                MinimumThreshold = s.MinimumThreshold 
            }).Take(5).ToList();

            // Load pending scans
            var scans = await Mediator.Send(new GetScanQueueQuery());
            pendingScansCount = scans.Count(s => s.Status == Domain.ScanStatus.Pending || s.Status == Domain.ScanStatus.Processing);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dashboard data");
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task Search()
    {
        await LoadDashboardData();
    }
    
    private async Task DecrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new DecrementInventoryCommand(itemId));
            await ToastService.ShowInfo("Item count decreased");
            await LoadDashboardData();
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error updating item");
        }
    }
    
    private async Task IncrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new IncrementInventoryCommand(itemId));
            await ToastService.ShowSuccess("Item count increased");
            await LoadDashboardData();
        }
        catch (Exception ex)
        {
            await ToastService.ShowError("Error updating item");
        }
    }
}
    
    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">Previous</button>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(i)">@i</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">Next</button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private List<InventoryItemDto>? inventoryItems;
    private string searchTerm = "";
    private string selectedCategory = "";
    private int currentPage = 1;
    private int totalPages = 1;
    private bool isLoading = true;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadInventory();
    }
    
    private async Task LoadInventory()
    {
        isLoading = true;
        try
        {
            var result = await Mediator.Send(new GetInventoryListQuery(
                SearchTerm: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                Category: string.IsNullOrWhiteSpace(selectedCategory) ? null : selectedCategory,
                Page: currentPage,
                PageSize: 20
            ));
            
            inventoryItems = result.Items;
            totalPages = result.TotalPages;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading inventory");
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task Search()
    {
        currentPage = 1;
        await LoadInventory();
    }
    
    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        await LoadInventory();
    }
    
    private async Task DecrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new DecrementInventoryCommand(itemId));
            await LoadInventory();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error decrementing item {ItemId}", itemId);
        }
    }
    
    private async Task IncrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new IncrementInventoryCommand(itemId));
            await LoadInventory();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error incrementing item {ItemId}", itemId);
        }
    }
}