@page "/"
@using MediatR
@using ThePantry.Application.Commands
@using ThePantry.Application.Queries
@inject IMediator Mediator

<PageTitle>Pantry Dashboard</PageTitle>

<h1>Pantry Inventory</h1>

<div class="mb-3">
    <div class="row g-3">
        <div class="col-md-6">
            <input type="text" class="form-control" placeholder="Search items..." @bind="searchTerm" @oninput="OnSearchChanged" />
        </div>
        <div class="col-md-4">
            <select class="form-select" @bind="selectedCategory" @onchange="OnCategoryChanged">
                <option value="">All Categories</option>
                <option value="Pantry">Pantry</option>
                <option value="Refrigerator">Refrigerator</option>
                <option value="Freezer">Freezer</option>
                <option value="Spices">Spices</option>
                <option value="Other">Other</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check form-switch mt-2">
                <input class="form-check-input" type="checkbox" id="belowThreshold" @bind="showBelowThreshold" @onchange="OnThresholdChanged">
                <label class="form-check-label" for="belowThreshold">Below Min</label>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (inventoryItems.Count == 0)
{
    <div class="alert alert-info">
        No inventory items found. Go to "Add Items" to add your first item!
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th class="text-center">On Hand</th>
                <th class="text-center">Min</th>
                <th class="text-center">Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in inventoryItems)
            {
                <tr class="@(item.OnHandCount < item.MinimumThreshold ? "table-warning" : "")">
                    <td>
                        <strong>@item.Name</strong>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <br /><small class="text-muted">@item.Description</small>
                        }
                    </td>
                    <td>@item.Category</td>
                    <td class="text-center">
                        <span class="badge bg-@GetCountBadgeColor(item)">@item.OnHandCount</span>
                    </td>
                    <td class="text-center">@item.MinimumThreshold</td>
                    <td class="text-center">
                        @if (item.OnHandCount < item.MinimumThreshold)
                        {
                            <span class="badge bg-danger">Low</span>
                        }
                        else
                        {
                            <span class="badge bg-success">OK</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn btn-outline-danger" @onclick="() => DecrementItem(item.Id)" title="Use Item">
                                <span class="oi oi-minus"></span>
                            </button>
                            <button class="btn btn-outline-success" @onclick="() => IncrementItem(item.Id)" title="Add Item">
                                <span class="oi oi-plus"></span>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<InventoryItem> inventoryItems = new();
    private string searchTerm = "";
    private string selectedCategory = "";
    private bool showBelowThreshold = false;
    private bool isLoading = true;
    private System.Timers.Timer? searchTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadInventory();
    }

    private async Task LoadInventory()
    {
        isLoading = true;
        try
        {
            inventoryItems = await Mediator.Send(new GetInventoryListQuery(
                SearchTerm: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                Category: string.IsNullOrWhiteSpace(selectedCategory) ? null : selectedCategory,
                BelowThresholdOnly: showBelowThreshold ? true : false
            ));
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        DebounceSearch();
    }

    private void OnCategoryChanged(ChangeEventArgs e)
    {
        selectedCategory = e.Value?.ToString() ?? "";
        _ = LoadInventory();
    }

    private void OnThresholdChanged(ChangeEventArgs e)
    {
        showBelowThreshold = e.Value is bool b && b;
        _ = LoadInventory();
    }

    private void DebounceSearch()
    {
        searchTimer?.Stop();
        searchTimer?.Dispose();
        searchTimer = new System.Timers.Timer(300);
        searchTimer.Elapsed += async (s, e) =>
        {
            searchTimer?.Stop();
            await InvokeAsync(async () => await LoadInventory());
        };
        searchTimer.Start();
    }

    private async Task DecrementItem(int id)
    {
        await Mediator.Send(new DecrementInventoryCommand(id));
        await LoadInventory();
    }

    private async Task IncrementItem(int id)
    {
        await Mediator.Send(new IncrementInventoryCommand(id));
        await LoadInventory();
    }

    private string GetCountBadgeColor(InventoryItem item)
    {
        if (item.OnHandCount == 0) return "dark";
        if (item.OnHandCount < item.MinimumThreshold) return "warning";
        return "primary";
    }
}
