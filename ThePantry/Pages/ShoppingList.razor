@page "/shopping-list"
@using MediatR
@using ThePantry.Application.Queries
@inject IMediator Mediator

<PageTitle>Shopping List - ThePantry</PageTitle>

<h1>Shopping List</h1>

<p class="text-muted">Items below minimum threshold that need to be purchased.</p>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (shoppingItems.Count == 0)
{
    <div class="alert alert-success">
        Your pantry is well-stocked! No items below minimum threshold.
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-header bg-warning">
            <h5 class="mb-0">@shoppingItems.Count items need to be purchased</h5>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Category</th>
                        <th class="text-center">On Hand</th>
                        <th class="text-center">Minimum</th>
                        <th class="text-center">Need</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in shoppingItems)
                    {
                        <tr class="table-warning">
                            <td>
                                <strong>@item.Name</strong>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <br /><small class="text-muted">@item.Description</small>
                                }
                            </td>
                            <td>@item.Category</td>
                            <td class="text-center">
                                <span class="badge bg-@GetCountBadge(item)">@item.OnHandCount</span>
                            </td>
                            <td class="text-center">@item.MinimumThreshold</td>
                            <td class="text-center">
                                <span class="badge bg-danger fs-6">
                                    @GetDeficit(item)
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<InventoryItem> shoppingItems = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadShoppingList();
    }

    private async Task LoadShoppingList()
    {
        isLoading = true;
        try
        {
            shoppingItems = await Mediator.Send(new GetShoppingListQuery());
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetDeficit(InventoryItem item)
    {
        return Math.Max(0, item.MinimumThreshold - item.OnHandCount);
    }

    private string GetCountBadge(InventoryItem item)
    {
        if (item.OnHandCount == 0) return "dark";
        return "warning";
    }
}