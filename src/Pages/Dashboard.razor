@page "/"
@using MediatR
@using ThePantry.Application.Commands
@using ThePantry.Application.Queries
@using ThePantry.Services
@inject IMediator Mediator
@inject ILogger<Dashboard> Logger
@inject ToastService ToastService

<PageTitle>Dashboard - The Pantry</PageTitle>

<h1>Dashboard</h1>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stat-card text-center flex-column">
            <div class="stat-icon bg-primary text-white mb-2">
                <span class="oi oi-list"></span>
            </div>
            <div>
                <div class="stat-label">Total Items</div>
                <div class="stat-value">@totalItemsCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card text-center flex-column">
            <div class="stat-icon bg-warning text-dark mb-2">
                <span class="oi oi-warning"></span>
            </div>
            <div>
                <div class="stat-label">Low Stock</div>
                <div class="stat-value">@lowStockCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card text-center flex-column">
            <div class="stat-icon bg-info text-white mb-2">
                <span class="oi oi-monitor"></span>
            </div>
            <div>
                <div class="stat-label">Pending Scans</div>
                <div class="stat-value">@pendingScansCount</div>
            </div>
        </div>
    </div>
</div>

@if (useSoonItems != null && useSoonItems.Any())
{
    <div class="card mb-4 border-info">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Use Soon</h5>
            <span class="badge bg-light text-dark">Expiring or Open</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Reason</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in useSoonItems)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@item.Name</div>
                                    @if (item.IsOpened)
                                    {
                                        <small class="text-primary"><span class="oi oi-envelope-open me-1"></span>Opened</small>
                                    }
                                </td>
                                <td>
                                    @if (item.IsOpened && (item.OpenedDate?.AddDays(item.UseWithinDays) - DateTime.UtcNow)?.TotalDays <= 3)
                                    {
                                        <span class="badge bg-warning text-dark">Use within @item.UseWithinDays days of opening</span>
                                    }
                                    else if ((item.ExpiryDate - DateTime.UtcNow).TotalDays <= 7)
                                    {
                                        <span class="badge bg-danger">Expiring soon (@item.ExpiryDate.ToLocalTime().ToString("d"))</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DecrementItem(item.Id)" title="Use Item">
                                        <span class="oi oi-minus"></span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (lowStockItems != null && lowStockItems.Any())
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Low Stock Alert</h5>
            <span class="badge bg-danger">Action Required</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Category</th>
                            <th>Stock</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in lowStockItems)
                        {
                            <tr>
                                <td class="fw-bold">@item.Name</td>
                                <td><span class="badge bg-light text-dark">@item.Category</span></td>
                                <td>
                                    <span class="text-danger fw-bold">@item.OnHandCount</span>
                                    <span class="text-muted small">/ @item.MinimumThreshold</span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => IncrementItem(item.Id)">
                                        <span class="oi oi-plus"></span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light text-end">
            <a href="shopping-list" class="btn btn-sm btn-primary">View Shopping List</a>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Quick Inventory Search</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <span class="oi oi-magnifying-glass text-muted"></span>
                    </span>
                    <input type="text" class="form-control border-start-0" placeholder="Search items..." @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                </div>
            </div>
            <div class="col-md-4">
                <select class="form-select" @bind="selectedCategory">
                    <option value="">All Categories</option>
                    <option value="Pantry">Pantry</option>
                    <option value="Refrigerator">Refrigerator</option>
                    <option value="Freezer">Freezer</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="Search">Search</button>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (inventoryItems == null || inventoryItems.Count == 0)
{
    <div class="alert alert-info">
        No inventory items found. Go to "Add Items" to add your first item!
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th class="text-center">On Hand</th>
                    <th class="text-center">Min</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in inventoryItems)
                {
                    <tr class="@(item.IsBelowThreshold ? "table-warning" : "")">
                        <td>
                            <div class="d-flex align-items-center">
                                <strong>@item.Name</strong>
                                @if (item.IsOpened)
                                {
                                    <span class="oi oi-envelope-open ms-2 text-primary" title="Opened"></span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <small class="text-muted">@item.Description</small>
                            }
                        </td>
                        <td>@item.Category</td>
                        <td class="text-center">@item.OnHandCount</td>
                        <td class="text-center">@item.MinimumThreshold</td>
                        <td class="text-center">
                            @if (item.IsBelowThreshold)
                            {
                                <span class="badge bg-warning text-dark">Low Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">In Stock</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => ToggleOpened(item.Id)" title="@(item.IsOpened ? "Mark as Closed" : "Mark as Opened")">
                                    <span class="oi @(item.IsOpened ? "oi-envelope-closed" : "oi-envelope-open")"></span>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DecrementItem(item.Id)" title="Use Item">
                                    <span class="oi oi-minus"></span>
                                </button>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => IncrementItem(item.Id)" title="Add Item">
                                    <span class="oi oi-plus"></span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<InventoryItemDto>? inventoryItems;
    private List<InventoryItemDto>? lowStockItems;
    private List<InventoryItemDto>? useSoonItems;
    private int totalItemsCount;
    private int lowStockCount;
    private int pendingScansCount;
    
    private string searchTerm = "";
    private string selectedCategory = "";
    private bool isLoading = true;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }
    
    private async Task LoadDashboardData()
    {
        isLoading = true;
        try
        {
            // Load inventory for search
            var inventoryResult = await Mediator.Send(new GetInventoryListQuery(
                SearchTerm: string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
                Category: string.IsNullOrWhiteSpace(selectedCategory) ? null : selectedCategory,
                Page: 1,
                PageSize: 10
            ));
            inventoryItems = inventoryResult.Items;
            totalItemsCount = inventoryResult.TotalCount;

            // Load low stock items
            var shoppingList = await Mediator.Send(new GetShoppingListQuery());
            lowStockCount = shoppingList.Count;
            lowStockItems = shoppingList.Select(s => new InventoryItemDto 
            { 
                Id = s.Id, 
                Name = s.Name, 
                Category = s.Category, 
                OnHandCount = s.OnHandCount, 
                MinimumThreshold = s.MinimumThreshold 
            }).Take(5).ToList();

            // Load pending scans
            var scans = await Mediator.Send(new GetScanQueueQuery());
            pendingScansCount = scans.Count(s => s.Status == Domain.ScanStatus.Pending || s.Status == Domain.ScanStatus.Processing);

            // Load "Use Soon" items
            var allInventory = await Mediator.Send(new GetInventoryListQuery(PageSize: 1000));
            useSoonItems = allInventory.Items
                .Where(i => i.OnHandCount > 0 && (
                    (i.IsOpened && (i.ExpiryDate - DateTime.UtcNow).TotalDays <= 3) ||
                    (i.ExpiryDate - DateTime.UtcNow).TotalDays <= 7
                ))
                .OrderBy(i => i.ExpiryDate)
                .Take(5)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError("Error loading dashboard data");
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private async Task Search()
    {
        await LoadDashboardData();
    }

    private async Task ToggleOpened(int id)
    {
        var result = await Mediator.Send(new ToggleOpenedStatusCommand(id));
        if (result != null)
        {
            await ToastService.ShowSuccess("Item status updated");
            await LoadDashboardData();
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }
    
    private async Task DecrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new DecrementInventoryCommand(itemId));
            await ToastService.ShowInfo("Item count decreased");
            await LoadDashboardData();
        }
        catch (Exception)
        {
            await ToastService.ShowError("Error updating item");
        }
    }
    
    private async Task IncrementItem(int itemId)
    {
        try
        {
            await Mediator.Send(new IncrementInventoryCommand(itemId));
            await ToastService.ShowSuccess("Item count increased");
            await LoadDashboardData();
        }
        catch (Exception)
        {
            await ToastService.ShowError("Error updating item");
        }
    }
}