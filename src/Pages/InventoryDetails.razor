@page "/inventory/details/{id:int}"
@using ThePantry.Application.Queries
@using ThePantry.Application.Commands
@using ThePantry.Application.Services
@using ThePantry.Domain
@using ThePantry.Services
@inject IMediator Mediator
@inject ToastService ToastService
@inject NavigationManager NavigationManager
@inject IProductLookupService ProductLookupService

<PageTitle>Details: @(inventoryItem?.Name ?? "Item") - The Pantry</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Inventory Item Details</h3>
    <div>
        @if (inventoryItem != null && inventoryItem.Skus != null && inventoryItem.Skus.Any())
        {
            <button class="btn btn-outline-primary me-2" @onclick="RefreshFromOpenFoodFacts" disabled="@isRefreshing">
                @if (isRefreshing)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span class="ms-1">Refreshing...</span>
                }
                else
                {
                    <span class="oi oi-reload"></span>
                    <span class="ms-1">Refresh from OpenFoodFacts</span>
                }
            </button>
        }
        <button class="btn btn-outline-secondary" @onclick='() => NavigationManager.NavigateTo("inventory")'>
            <span class="oi oi-arrow-left"></span> Back to Inventory
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (inventoryItem == null || inventoryItem.Id == 0)
{
    <div class="alert alert-danger">
        Inventory item not found.
    </div>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Item Information</h5>
                </div>
                <div class="card-body text-center">
                    <ThePantry.Shared.Components.ProductImage ImageUrl="@inventoryItem.ImageUrl" Size="ThePantry.Shared.Components.ProductImage.ImageSize.Medium" Style="max-width: 100%; height: 200px; object-fit: contain; margin-bottom: 1rem;" />
                    <h4 class="card-title">@inventoryItem.Name</h4>
                    <p class="text-muted">@inventoryItem.Description</p>
                    <hr />
                    <div class="mb-2"><strong>Category:</strong> <span class="badge bg-info">@inventoryItem.Category</span></div>
                    <div class="mb-2"><strong>SKUs:</strong> 
                        @if (inventoryItem.Skus != null && inventoryItem.Skus.Any())
                        {
                            @foreach (var sku in inventoryItem.Skus)
                            {
                                <code class="d-block">@sku</code>
                            }
                        }
                        else
                        {
                            <code>N/A</code>
                        }
                    </div>
                    <div class="mb-2"><strong>On Hand:</strong> <span class="h5 @(inventoryItem.IsBelowThreshold ? "text-danger" : "text-success")">@inventoryItem.OnHandCount</span></div>
                    <div class="mb-2"><strong>Minimum:</strong> @inventoryItem.MinimumThreshold</div>
                    <div class="mb-2"><strong>Shelf Life:</strong> @inventoryItem.ShelfLifeDays days</div>
                    <div class="mb-2"><strong>Use Within:</strong> @inventoryItem.UseWithinDays days (when opened)</div>
                    <div class="mb-2"><strong>Expiry Date:</strong> @inventoryItem.ExpiryDate.ToLocalTime().ToString("d")</div>
                    <div class="mb-2"><strong>Status:</strong> 
                        @if (inventoryItem.IsBelowThreshold)
                        {
                            <span class="badge bg-warning text-dark">Low Stock</span>
                        }
                        else
                        {
                            <span class="badge bg-success">In Stock</span>
                        }
                        @if (inventoryItem.IsOpened)
                        {
                            <span class="badge bg-primary ms-1">Opened</span>
                        }
                    </div>
                    @if (inventoryItem.IsOpened && inventoryItem.OpenedDate.HasValue)
                    {
                        <div class="alert alert-info mt-3 py-2 small">
                            <span class="oi oi-info me-1"></span>
                            Opened on @inventoryItem.OpenedDate.Value.ToLocalTime().ToString("g").
                            Use by @inventoryItem.OpenedDate.Value.AddDays(inventoryItem.UseWithinDays).ToLocalTime().ToString("d").
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-white">Usage History</h5>
                    <span class="badge bg-light text-dark">Total Used: @totalUsageCount</span>
                </div>
                <div class="card-body p-0">
                    @if (usageHistory.Count == 0)
                    {
                        <div class="p-3 text-muted">No usage history available.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date & Time</th>
                                        <th class="text-center">Quantity Used</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var history in usageHistory)
                                    {
                                        <tr>
                                            <td>@history.Timestamp.ToLocalTime().ToString("f")</td>
                                            <td class="text-center"><span class="badge bg-secondary">-@history.QuantityUsed</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int id { get; set; }
    
    private bool isLoading = true;
    private bool isRefreshing = false;
    private InventoryItemDto? inventoryItem;
    private List<UsageHistoryDto> usageHistory = new();
    private int totalUsageCount = 0;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            var result = await Mediator.Send(new GetInventoryWithUsageHistoryQuery(id));
            inventoryItem = result.Item;
            usageHistory = result.UsageHistory;
            totalUsageCount = result.TotalUsageCount;
        }
        catch (Exception ex)
        {
            // Log error
            Console.WriteLine($"Error loading inventory details: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshFromOpenFoodFacts()
    {
        if (inventoryItem == null || inventoryItem.Skus == null || !inventoryItem.Skus.Any()) return;

        isRefreshing = true;
        try
        {
            // Use the first SKU for lookup
            var sku = inventoryItem.Skus.First();
            var result = await ProductLookupService.LookupAsync(sku);

            if (result != null)
            {
                var command = new UpdateInventoryItemCommand(
                    inventoryItem.Id,
                    inventoryItem.Name.StartsWith("Unknown Product", StringComparison.OrdinalIgnoreCase) ? result.Name : inventoryItem.Name,
                    result.Description ?? inventoryItem.Description,
                    inventoryItem.Category,
                    inventoryItem.OnHandCount,
                    inventoryItem.MinimumThreshold,
                    inventoryItem.ShelfLifeDays,
                    inventoryItem.UseWithinDays,
                    inventoryItem.ImageUrl ?? result.ImageUrl,
                    inventoryItem.Skus
                );

                var success = await Mediator.Send(command);
                if (success)
                {
                    await ToastService.ShowSuccess("Item updated from OpenFoodFacts");
                    await LoadData();
                }
                else
                {
                    await ToastService.ShowError("Failed to update item");
                }
            }
            else
            {
                await ToastService.ShowWarning("Product not found in OpenFoodFacts");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing from OpenFoodFacts: {ex.Message}");
            await ToastService.ShowError("Error refreshing data");
        }
        finally
        {
            isRefreshing = false;
        }
    }
}